%%%% PGF-TIKZ
\usepackage{tikz}
\usetikzlibrary{calc}


\hypersetup{colorlinks=true}

%%% Necessaire
\usetikzlibrary{arrows,shapes} 
\tikzstyle{every picture}+=[remember picture]

% pour gras
\tikzstyle{every picture}+=[very thick]


%% tikz écrase le \path du paquet url ; on le rétablit ici une fois pour
%% toutes (tikz réinstalle ses propres commandes localement dans chaque
%% tikzpicture, donc ceci ne gêne pas les dessins). Sans cela, les
%% \path{doi:...} produits par plainurl.bst dans le .bbl font échouer
%% la compilation.
\RequirePackage{url}
\DeclareUrlCommand\path{\urlstyle{tt}}


