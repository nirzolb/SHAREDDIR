\newcounter{truchyperref}
\newcommand{\newname}{truc\thetruchyperref}
\newcommand{\mypdfbookmark}[1]{ \pdfbookmark[0]{{#1}}{\newname}
  \addtocounter{truchyperref}{1} }
%
\notprosper{
\newcommand{\slidessbookmark}[1]{\foilhead[-10mm]{\colortitre{#1}}}
\ifthenelse{\boolean{pppower}} {
\newcommand{\sliderotssbookmark}[1]{\slidessbookmark{#1}}}
{\newcommand{\sliderotssbookmark}[1]{\rotatefoilhead[-10mm]{\colortitre{#1}}}}
%
\newcommand{\slidebookmark}[2]{\slidessbookmark{#1}
  \pdfonly{\mypdfbookmark{#2}}}
\newcommand{\sliderotbookmark}[2]{\sliderotssbookmark{#1}
  \pdfonly{\mypdfbookmark{#2}}}
%
\providecommand{\slide}[1]{\slidebookmark{#1}{#1}}
\newcommand{\sliderot}[1]{\sliderotbookmark{#1}{#1}}

}
\ifprosper{
\newcommand{\dslide}[1]{\finmyslidesibesoin \begin{myslide}{#1}}
\newcommand{\dsliderot}[1]{\finmyslidesibesoin \begin{myslide}{#1}}
}




