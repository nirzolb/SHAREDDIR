\ifprosper{
 \newcommand{\contenu}[1]{ \finmyslidesibesoin \part{#1}}
}
\ifbeamer{
  \providecommand{\contenu}[1]{ \title{#1} \maketitle}
}

\ifprosper{
\newenvironment{myslide}[1]{\begin{slide}{#1} \setboolean{endslideneeded}{true}
    \vspace{-0.5cm}}{\finitemizesibesoin \end{slide} \setboolean{endslideneeded}{false} }
\newenvironment{myslidee}[1]{\begin{slide}{} \setboolean{endslideneeded}{true}
    \vspace{-0.5cm}}{\finitemizesibesoin \end{slide} \setboolean{endslideneeded}{false} }
}
\ifbeamer{
\newenvironment{myslide}[1]{\begin{frame} \frametitle{#1}}
  {\end{frame}}
\newenvironment{myslidee}[1]{\begin{frame}}
  {\end{frame}}
}




