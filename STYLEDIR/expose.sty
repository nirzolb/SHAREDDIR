%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%        Permettre degeulasse latex
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%% Motivation: si 
%% 1: \begin{document} changé en \begin{document} \begin{degeulasse}
%% 2: \end{document} changé en \end{degeulasse} \end{document}
%% 3: chaque \slide et \sliderot en \dslide et \dsliderot
%% 4: chaque \item en \myitem (en fait slt le premier de chaque slide)
%% Alors on a 
%%     A: la compatibilité complète avec style ppower
%%     B: \myitem qui génére un item ss se préocupper si itemize
%%     ouvert ou pas
%%     C: \newslide qui coupe la page à cet endroit (et s'occupe de
%%     gérer itemize et slide)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

  \newboolean{endslideneeded}
  \setboolean{endslideneeded}{false}
  \newcommand{\finmyslidesibesoin}{}
  \newcommand{\beginitemizesibesoin}{}
  \newcommand{\finitemizesibesoin}{}

  \newcommand{\degeuitem}{\item}



\newenvironment{degeulasse}{
  \renewcommand{\finmyslidesibesoin}{\ifthenelse{\boolean{endslideneeded}}{ \end{myslide}
    \setboolean{endslideneeded}{false}}{}}
   \newcommand\findocument{\finmyslidesibesoin}
   \renewcommand\newslide{\finmyslidesibesoin \dslide{}}
%
     \renewcommand{\beginitemizesibesoin}{\ifnum \csname
    @itemdepth\endcsname=0 \begin{itemize} \fi}
  \renewcommand{\finitemizesibesoin}{\ifnum \csname
    @itemdepth\endcsname=1 \end{itemize} \fi}
%
  \renewcommand\degeuitem{\beginitemizesibesoin \item}
}{\finmyslidesibesoin}


